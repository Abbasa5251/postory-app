# Compose interpolation variables for the self-hosted deployment.
# Copy to `deploy.env` and pass with: docker compose --env-file deploy.env ...
# These are consumed by docker-compose.yml itself (NOT by the app process).

# Redis password — shared by the redis container (--requirepass) and the SRH
# connection string. Generate: openssl rand -base64 32
REDIS_PASSWORD=

# SRH REST token — the app authenticates to SRH with this value. It MUST equal
# UPSTASH_REDIS_REST_TOKEN in .env.production. Generate: openssl rand -base64 32
SRH_TOKEN=

# Public domain Caddy serves + gets a TLS cert for (e.g. app.postory.example).
APP_DOMAIN=
