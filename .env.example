# Neon Postgres connection string
DATABASE_URL=

# better-auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Base URL of the app (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional — Google sign-in is disabled until both are set)
# Redirect URI to register: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend — transactional email (verification, password reset, org invitations)
RESEND_API_KEY=
