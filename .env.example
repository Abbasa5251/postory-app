# Postgres connection string (postgres://…). Any Postgres — a local container
# or a cloud provider's direct connection endpoint. Uses the standard
# node-postgres driver (no vendor SDK).
DATABASE_URL=

# better-auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Base URL of the app (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional — Google sign-in is disabled until both are set)
# Redirect URI to register: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend — transactional email (verification, password reset, org invitations)
RESEND_API_KEY=
# Verified-domain sender, e.g. "POSTORY <no-reply@postory.app>".
# Optional in dev and local/CI builds (sandbox fallback); REQUIRED in
# production (Vercel builds and server boot fail without it).
EMAIL_FROM=

# Redis connection string (redis://… or rediss://…) — auth rate limits +
# better-auth session secondaryStorage (ADR-011). Uses the standard ioredis
# driver (no vendor SDK). Optional in dev and local/CI builds (sessions stay
# DB-only, rate limiting is production-only anyway); REQUIRED in production
# (Vercel builds and server boot fail without it).
REDIS_URL=

# Sentry error reporting (A6). All optional — Sentry no-ops without a DSN; a
# production server only WARNs (never fails) when SENTRY_DSN is unset.
# SENTRY_DSN: server/edge runtime · NEXT_PUBLIC_SENTRY_DSN: browser.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Build-time only — source-map upload via the Sentry bundler plugin. Skipped
# automatically when SENTRY_AUTH_TOKEN is absent (local/CI builds unaffected).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

ZERNIO_API_KEY=
