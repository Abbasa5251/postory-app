# App + migrate RUNTIME environment for the self-hosted Docker deployment.
# Copy to `.env.production` (gitignored) on the host. Consumed by the `app` and
# `migrate` services via env_file. Never baked into the image.

# Managed Postgres (Neon or another managed PG). node-postgres reads sslmode
# from the URL — keep ?sslmode=require for a managed instance. Must be PG18+
# (schema uses native uuidv7()).
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# better-auth. Generate the secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://app.postory.example

# Redis via the SRH sidecar (NOT Upstash cloud). The URL is the in-network SRH
# service; the token MUST equal SRH_TOKEN in deploy.env. Both are REQUIRED at
# runtime — the ADR-011 boot guard throws at startup if either is missing.
UPSTASH_REDIS_REST_URL=http://srh:80
UPSTASH_REDIS_REST_TOKEN=

# Resend transactional email. EMAIL_FROM is REQUIRED in production (the email
# service refuses the sandbox fallback); the boot guard enforces it.
RESEND_API_KEY=
EMAIL_FROM=POSTORY <no-reply@postory.example>

# Google OAuth (optional — sign-in stays disabled until both are set).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Zernio publishing (required for account connection / publishing to work).
ZERNIO_API_KEY=

# Sentry server/edge DSN (optional; server only WARNs when unset).
SENTRY_DSN=
# NOTE: NEXT_PUBLIC_SENTRY_DSN is a BUILD-time arg (inlined into the client
# bundle), NOT a runtime var — pass it via `docker build --build-arg`, not here.
