{
  "name": "postory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:css": "stylelint \"src/**/*.css\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:authz": "vitest run --project authz",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "auth:schema": "SKIP_ENV_VALIDATION=1 auth generate --config src/server/auth/auth.ts --output src/db/schemas/auth.ts --y",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@better-auth-ui/core": "^1.6.27",
    "@better-auth-ui/react": "^1.6.27",
    "@better-auth/drizzle-adapter": "^1.7.0-rc.1",
    "@neondatabase/serverless": "^1.1.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.1.0",
    "@sentry/nextjs": "^10.66.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-query": "^5.101.2",
    "@upstash/redis": "^1.38.0",
    "better-auth": "^1.7.0-rc.1",
    "bowser": "^2.14.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-rc.4",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "resend": "^6.17.2",
    "server-only": "^0.0.1",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "better-auth": {
      "drizzle-orm": "$drizzle-orm",
      "drizzle-kit": "$drizzle-kit"
    },
    "kysely": "^0.28.17"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "auth": "^1.7.0-rc.1",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^1.0.0-rc.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
